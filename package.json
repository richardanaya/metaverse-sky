  "type": "module",
  "sideEffects": false,
  "author": "Richard Anaya",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/richardanaya/metaverse-sky.git"
  },
  "homepage": "https://github.com/richardanaya/metaverse-sky#readme",
  "bugs": {
    "url": "https://github.com/richardanaya/metaverse-sky/issues"
  },
